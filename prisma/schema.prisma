generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  phone         String    @unique
  email         String?   @unique
  country       String    @default("GH")
  kycStatus     String    @default("PENDING")
  averageRating Decimal?  @db.Decimal(3, 2)
  totalRatings  Int       @default(0)
  isSuspended   Boolean   @default(false)
  showPhone     Boolean   @default(false)
  showEmail     Boolean   @default(false)
  showWhatsapp  Boolean   @default(false)
  businessPhone String?
  businessEmail String?
  storeType     String    @default("BASIC")
  storeName     String?
  storeBanner   String?
  storeBio      String?
  storeTheme    String    @default("Minimal")
  storeLinks    Json      @default("[]")
  storeActive   Boolean   @default(true)
  isOnline      Boolean   @default(false)
  lastSeen      DateTime?
  createdAt     DateTime  @default(now())
  listings      Listing[]
  storeFollowers     StoreFollow[]  @relation("SellerFollows")
  storeFollowing     StoreFollow[]  @relation("FollowerFollows")
  receivedReviews    StoreReview[]  @relation("ReceivedStoreReviews")
  givenReviews       StoreReview[]  @relation("GivenStoreReviews")
  listingLikes       ListingLike[]
  listingComments    ListingComment[]
  subscriptions      UserSubscription[]
  listingBoosts      ListingBoost[]

  @@map("users")
}

model StoreFollow {
  id         String   @id @default(uuid())
  followerId String
  sellerId   String
  createdAt  DateTime @default(now())

  follower User @relation("FollowerFollows", fields: [followerId], references: [id], onDelete: Cascade)
  seller   User @relation("SellerFollows",   fields: [sellerId],   references: [id], onDelete: Cascade)

  @@unique([followerId, sellerId])
  @@map("store_follows")
}

model ListingLike {
  id        String   @id @default(uuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
  @@map("listing_likes")
}

model ListingComment {
  id        String   @id @default(uuid())
  listingId String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId],  references: [id], onDelete: Cascade)

  @@map("listing_comments")
}

model StoreReview {
  id          String   @id @default(uuid())
  reviewerId  String
  sellerId    String
  stars       Int
  body        String?
  sellerReply String?
  createdAt   DateTime @default(now())

  reviewer User @relation("GivenStoreReviews",    fields: [reviewerId], references: [id], onDelete: Cascade)
  seller   User @relation("ReceivedStoreReviews", fields: [sellerId],   references: [id], onDelete: Cascade)

  @@unique([reviewerId, sellerId])
  @@map("store_reviews")
}

model FeeConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("fee_configs")
}

model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Decimal  @db.Decimal(10, 2)
  category    String
  images      String[]
  sellerId    String
  country     String   @default("GH")
  status      String   @default("ACTIVE")
  storeType   String   @default("BASIC")
  views       Int      @default(0)
  condition   String   @default("NEW")
  featured         Boolean   @default(false)
  flashDeal        Boolean   @default(false)
  flashDealExpiry  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt   DateTime @updatedAt
  seller      User     @relation(fields: [sellerId], references: [id])
  likes       ListingLike[]
  comments    ListingComment[]
  boosts      ListingBoost[]

  @@map("listings")
}

model SubscriptionPlan {
  id          String   @id @default(dbgenerated("gen_random_uuid()::text"))
  name        String
  slug        String   @unique
  price       Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("GHS")
  interval    String   @default("month")
  maxListings Int      @default(5)
  freeBoosts  Int      @default(0)
  features    Json     @default("[]")
  badge       String?
  badgeColor  String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

model UserSubscription {
  id            String   @id @default(dbgenerated("gen_random_uuid()::text"))
  userId        String
  planId        String
  status        String   @default("ACTIVE")
  startDate     DateTime @default(now())
  endDate       DateTime
  autoRenew     Boolean  @default(true)
  paymentMethod String?
  momoRef       String?
  createdAt     DateTime @default(now())

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@map("user_subscriptions")
}

model BoostPackage {
  id           String   @id @default(dbgenerated("gen_random_uuid()::text"))
  name         String
  slug         String   @unique
  price        Decimal  @db.Decimal(10, 2)
  durationDays Int
  description  String?
  badge        String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)

  @@map("boost_packages")
}

model ListingBoost {
  id        String   @id @default(dbgenerated("gen_random_uuid()::text"))
  listingId String
  userId    String
  boostType String   @default("BASIC")
  price     Decimal  @db.Decimal(10, 2)
  startDate DateTime @default(now())
  endDate   DateTime
  status    String   @default("ACTIVE")
  momoRef   String?
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("listing_boosts")
}

model PromoCode {
  id              String    @id @default(dbgenerated("gen_random_uuid()::text"))
  code            String    @unique
  discountPercent Int       @default(0)
  maxUses         Int?
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())

  @@map("promo_codes")
}

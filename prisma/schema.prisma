generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  firstName     String
  lastName      String
  phone         String    @unique
  email         String?   @unique
  country       String    @default("GH")
  kycStatus     String    @default("PENDING")
  averageRating Decimal?  @db.Decimal(3, 2)
  totalRatings  Int       @default(0)
  isSuspended   Boolean   @default(false)
  showPhone     Boolean   @default(false)
  showEmail     Boolean   @default(false)
  showWhatsapp  Boolean   @default(false)
  businessPhone String?
  businessEmail String?
  storeType     String    @default("BASIC")
  storeName     String?
  storeBanner   String?
  storeBio      String?
  storeTheme    String    @default("Minimal")
  storeLinks    Json      @default("[]")
  storeActive   Boolean   @default(true)
  createdAt     DateTime  @default(now())
  listings      Listing[]

  @@map("users")
}

model FeeConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("fee_configs")
}

model Listing {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Decimal  @db.Decimal(10, 2)
  category    String
  images      String[]
  sellerId    String
  country     String   @default("GH")
  status      String   @default("ACTIVE")
  storeType   String   @default("BASIC")
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  seller      User     @relation(fields: [sellerId], references: [id])

  @@map("listings")
}
